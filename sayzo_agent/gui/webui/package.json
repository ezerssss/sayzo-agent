{
  "name": "sayzo-setup-webui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "python ../../../scripts/sync_brand_assets.py",
    "dev": "vite",
    "predev:mock": "python ../../../scripts/sync_brand_assets.py",
    "dev:mock": "vite --mode mock",
    "predev:finish-signup": "python ../../../scripts/sync_brand_assets.py",
    "dev:finish-signup": "vite --mode mock --open /#preview=finish-signup",
    "predev:hud": "python ../../../scripts/sync_brand_assets.py",
    "dev:hud": "vite --mode mock --open /#route=hud&demo=1",
    "predev:hud-pill": "python ../../../scripts/sync_brand_assets.py",
    "dev:hud-pill": "vite --mode mock --open /#preview=hud-pill",
    "predev:hud-card": "python ../../../scripts/sync_brand_assets.py",
    "dev:hud-card": "vite --mode mock --open /#preview=hud-card",
    "predev:hud-toast": "python ../../../scripts/sync_brand_assets.py",
    "dev:hud-toast": "vite --mode mock --open /#preview=hud-toast",
    "predev:hud-actionable": "python ../../../scripts/sync_brand_assets.py",
    "dev:hud-actionable": "vite --mode mock --open /#preview=hud-actionable",
    "prebuild": "python ../../../scripts/sync_brand_assets.py",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
